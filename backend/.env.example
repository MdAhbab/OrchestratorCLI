# ============================================================================
# IBM Bob Backend - Environment Configuration Example
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control!

# ============================================================================
# Application Settings
# ============================================================================

# Application environment (development, staging, production)
APP_ENV=development

# Application name
APP_NAME="IBM Bob"

# Application version
APP_VERSION=1.0.0

# Debug mode (true/false) - enables detailed error messages and auto-reload
DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Use JSON format for logs (true/false) - recommended for production
LOG_JSON_FORMAT=false

# ============================================================================
# Server Configuration
# ============================================================================

# API host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
API_HOST=127.0.0.1

# API port
API_PORT=8000

# Number of worker processes (for production with gunicorn/uvicorn)
WORKERS=1

# ============================================================================
# Database Configuration
# ============================================================================

# Database connection URL (async SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/bob.db

# Database file path used by backend runtime and init scripts
DATABASE_PATH=./data/bob.db

# Database connection pool size (for production databases)
DB_POOL_SIZE=5

# Database connection timeout (seconds)
DB_TIMEOUT=30

# Enable database query logging (true/false)
DB_ECHO=false

# ============================================================================
# CORS (Cross-Origin Resource Sharing) Settings
# ============================================================================

# Allowed origins (comma-separated list, or * for all)
# Example: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# Allowed HTTP methods
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Allowed headers
CORS_ALLOW_HEADERS=*

# ============================================================================
# File Storage Configuration
# ============================================================================

# Base directory for file uploads
UPLOAD_DIR=./uploads

# Maximum file size in MB
MAX_FILE_SIZE_MB=10

# Allowed file extensions (comma-separated)
ALLOWED_FILE_EXTENSIONS=.txt,.pdf,.md,.json,.yaml,.yml,.csv,.log

# Workspace directory for sessions
WORKSPACE_DIR=./workspace

# Temporary files directory
TEMP_DIR=./temp

# ============================================================================
# Encryption & Security
# ============================================================================

# Encryption key for sensitive data (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# IMPORTANT: Generate a new key for production!
ENCRYPTION_KEY=your-secret-encryption-key-here-change-in-production

# Secret key for session management (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# API key for authentication (optional, for API access control)
API_KEY=

# Token expiration time (seconds)
TOKEN_EXPIRATION=3600

# ============================================================================
# AI Provider Configuration
# ============================================================================

# OpenAI API Key
OPENAI_API_KEY=

# Anthropic API Key
ANTHROPIC_API_KEY=

# Google AI API Key
GOOGLE_API_KEY=

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# IBM Watson Configuration
# Speech-to-Text Service
STT_API_KEY=
STT_URL=

# Watsonx.ai Service
WATSONX_API_KEY=
WATSONX_PROJECT_ID=

# Default AI provider (openai, anthropic, google, azure)
DEFAULT_PROVIDER=openai

# Default model for each provider
DEFAULT_OPENAI_MODEL=gpt-4
DEFAULT_ANTHROPIC_MODEL=claude-3-opus-20240229
DEFAULT_GOOGLE_MODEL=gemini-pro

# ============================================================================
# Rate Limiting & Quotas
# ============================================================================

# Enable rate limiting (true/false)
RATE_LIMITING_ENABLED=true

# Requests per minute per user
RATE_LIMIT_PER_MINUTE=60

# Daily API call quota per user
DAILY_QUOTA=1000

# Maximum concurrent sessions per user
MAX_CONCURRENT_SESSIONS=5

# ============================================================================
# WebSocket Configuration
# ============================================================================

# WebSocket ping interval (seconds)
WS_PING_INTERVAL=30

# WebSocket ping timeout (seconds)
WS_PING_TIMEOUT=10

# Maximum WebSocket message size (bytes)
WS_MAX_MESSAGE_SIZE=1048576

# ============================================================================
# Session Management
# ============================================================================

# Session timeout (seconds) - auto-cleanup inactive sessions
SESSION_TIMEOUT=3600

# Session cleanup interval (seconds)
SESSION_CLEANUP_INTERVAL=300

# Maximum session history to keep
MAX_SESSION_HISTORY=100

# ============================================================================
# Analytics & Monitoring
# ============================================================================

# Enable analytics collection (true/false)
ANALYTICS_ENABLED=true

# Analytics retention period (days)
ANALYTICS_RETENTION_DAYS=90

# Enable performance monitoring (true/false)
PERFORMANCE_MONITORING=true

# Slow query threshold (seconds)
SLOW_QUERY_THRESHOLD=1.0

# ============================================================================
# External Services (Optional)
# ============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Redis URL for caching (optional)
REDIS_URL=

# Email service configuration (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ============================================================================
# Development Settings
# ============================================================================

# Auto-reload on code changes (development only)
RELOAD=true

# Enable API documentation (true/false)
ENABLE_DOCS=true

# API documentation URL path
DOCS_URL=/docs

# Enable test mode (disables certain features for testing)
TEST_MODE=false

# ============================================================================
# Production Settings
# ============================================================================

# Use HTTPS only (production)
HTTPS_ONLY=false

# Trusted proxy headers (for reverse proxy setups)
TRUSTED_HOSTS=*

# Enable request ID tracking
REQUEST_ID_HEADER=X-Request-ID

# ============================================================================
# Feature Flags
# ============================================================================

# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable voice input/output
ENABLE_VOICE=true

# Enable file uploads
ENABLE_FILE_UPLOADS=true

# Enable multi-provider orchestration
ENABLE_ORCHESTRATION=true

# ============================================================================
# Backup & Maintenance
# ============================================================================

# Automatic backup enabled (true/false)
AUTO_BACKUP_ENABLED=false

# Backup directory
BACKUP_DIR=./backups

# Backup interval (hours)
BACKUP_INTERVAL=24

# Number of backups to keep
BACKUP_RETENTION_COUNT=7

# ============================================================================
# Notes
# ============================================================================
# 
# 1. Generate secure keys for production:
#    python -c "import secrets; print(secrets.token_hex(32))"
#
# 2. Never commit .env file to version control
#
# 3. Use environment-specific .env files:
#    - .env.development
#    - .env.staging
#    - .env.production
#
# 4. Validate configuration on startup using run.py
#
# 5. For production, consider using a secrets management service
#    (AWS Secrets Manager, Azure Key Vault, HashiCorp Vault, etc.)
#
# ============================================================================
